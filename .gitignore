# --- Copyright-sensitive: never commit ---------------------------------------
# Original journal PDFs and any text extracted from them. This repository is
# published without these because the underlying articles are copyrighted by their
# respective publishers. Run the pipeline locally if you have legitimate access
# to the source PDFs.
library/*/*/pdfs/
library/*/*/text/

# Duplicate / retired PDFs retained locally for audit but never published.
library/*/*/_duplicates/

# Per-paper extraction bundles. These embed the full paper text verbatim and
# must never leave a local machine.
incoming/_bundles/

# Per-paper Layer-2 audit prompts (tools/audit_note.py --prompt-only output).
# These embed the full paper text verbatim, same as bundles. Keep local.
incoming/_audit_prompts/

# Validator-flagged notes — may contain reasons that reference local paths or
# wrong-PDF debugging context. Keep local.
incoming/_flagged/

# Faithfulness-audit reports (v2+). These reference paper-specific reasoning
# and verdicts that shouldn't be shipped publicly — and they're derived from
# the note + PDF anyway, so they can be regenerated locally with
# `python tools/audit_note.py notes/<paper_id>.md`.
incoming/_audits/

# Issue-level ingestion ledgers. These are local process records with repair
# notes, counts, and audit state; keep them private unless deliberately
# converted into public documentation.
incoming/_ledgers/

# Other incoming staging artifacts
incoming/*.pdf
incoming/*.txt

# Personal review drafts (folder kept private until ready for publication)
reviews/

# Daily work logs — personal end-of-day process notes generated by /daily-log.
# Kept local/private (this repo is public); delete this line to version-control them.
worklogs/

# --- Secrets / local config --------------------------------------------------
.env
.env.*
*.key
*.pem
secrets.*

# --- Claude Code session state ------------------------------------------------
# Ignore per-user session state while keeping the tracked `commands/` and
# `skills/` subtrees (these define the project's slash commands and skills).
.claude/*
!.claude/commands/
!.claude/commands/**
!.claude/skills/
!.claude/skills/**

# Serena MCP per-machine workspace state (created by agent sessions).
.serena/

# --- macOS / editor cruft ----------------------------------------------------
.DS_Store
._*
.AppleDouble
.LSOverride
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# --- Python ------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/
build/
dist/

# --- Ingestion pipeline working artifacts -------------------------------------
# Manifest backups (manifest.tsv.bak and manifest.tsv.<label>.bak) and the
# stub-audit reports (missing-pdfs.tsv/.xlsx, download-report.tsv). Local
# working files from the ingest/cleanup passes — regenerable, never published.
*.tsv.bak
*.tsv.*.bak
missing-pdfs.*
download-report.tsv
